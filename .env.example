# =============================================================
# ActaCofrade — example environment file
# Copy to `.env` and adjust values BEFORE running docker compose.
# `.env` is git-ignored. NEVER commit real secrets.
# Generate a strong JWT secret with:  openssl rand -base64 48
# =============================================================

# --- Database (PostgreSQL) ---
# Used by the `db` container and by the backend to build DB_URL.
POSTGRES_DB=actacofrade
POSTGRES_USER=actacofrade_user
POSTGRES_PASSWORD=change-me-strong-password

# --- Backend datasource ---
# DB_URL is overridden inside docker-compose; keep it for local (non-Docker) runs.
DB_URL=jdbc:postgresql://db:5432/actacofrade
DB_USER=actacofrade_user
DB_PASSWORD=change-me-strong-password

# --- JWT ---
# JWT_SECRET is required (min. 32 bytes); JWT_EXPIRATION_MS defaults to 24h.
JWT_SECRET=replace-with-a-random-string-at-least-32-bytes
JWT_EXPIRATION_MS=86400000

# --- CORS ---
# Comma separated list of allowed front-end origins. When the SPA is served
# by nginx the requests are same-origin and CORS is not used, but keep a
# sensible default for local Angular dev (`ng serve`).
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://localhost

# --- Avatar uploads ---
# AVATAR_MAX_SIZE drives Spring multipart limit; AVATAR_MAX_BYTES drives the
# extra image validation. Keep both in sync.
AVATAR_MAX_SIZE=2MB
AVATAR_MAX_BYTES=2097152
AVATAR_ALLOWED_TYPES=image/png,image/jpeg,image/webp,image/gif

# --- Super administrator ---
# Used only on first start to create the SUPER_ADMIN account if missing.
SUPERADMIN_EMAIL=
SUPERADMIN_PASSWORD=
SUPERADMIN_FULL_NAME=
